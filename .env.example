# Blackbaud API Credentials
CLIENT_ID=YOUR_CLIENT_ID
CLIENT_SECRET=YOUR_CLIENT_SECRET
SUBSCRIPTION_KEY=YOUR_SUBSCRIPTION_KEY

# JWT Secret (minimum 32 characters in production)
JWT_SECRET=YOUR_JWT_SECRET_AT_LEAST_32_CHARS

# Server
PORT=3333
HOST=localhost

# Public URL (set once OIT provisions domain/TLS)
# PUBLIC_BASE_URL=https://wdc.foundation.alaska.edu

# Redirect path for OAuth callback
REDIRECT_PATH=/redirect

# Redis
# REDIS_URL=redis://127.0.0.1:6379

# Single-user mode (set to true for single-analyst deployments)
# SINGLE_USER=false

# HTTPS redirect (enable when behind TLS proxy)
# FORCE_HTTPS=false

# CORS origins (comma-separated)
# CORS_ORIGIN=http://localhost:3333

# Logging level (debug, info, warn, error)
# LOG_LEVEL=info
